# Shell scripts and crontab files must be LF in the working tree so that
# Linux Docker containers can execute them via bind mount. Windows git.core.autocrlf
# would otherwise check out CRLF, breaking shebang lines and `set -o pipefail`.
.gitattributes    text eol=lf
scripts/*.sh      text eol=lf
scripts/*-crontab text eol=lf
caddy/Caddyfile   text eol=lf
