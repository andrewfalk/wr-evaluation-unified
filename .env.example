# wr-evaluation-unified — environment variables
# Copy to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=replace_with_random_64_char_hex
REFRESH_TOKEN_SECRET=replace_with_random_64_char_hex

# Comma-separated allowed CORS origins (required in production/intranet mode)
CORS_ORIGINS=https://wr.hospital.local

# Intranet hostname Caddy serves — must match what client PCs resolve via DNS/hosts
WR_DOMAIN=wr.hospital.local

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_in_production
# Full URL is built by docker-compose; override here for external DB:
# DATABASE_URL=postgres://wr_user:password@host:5432/wr_evaluation

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001              # 컨테이너 내부 app 포트. 보통 변경하지 않음 (Caddy가 외부 443 처리)
NODE_ENV=production
DEPLOYMENT_MODE=intranet       # intranet | standalone

# ── AI (all optional, disabled by default) ────────────────────────────────────
AI_PROVIDER=none               # none | internal | external
# AI_INTERNAL_ENDPOINT=http://ollama:11434
# AI_EXTERNAL_ENDPOINT=https://api.openai.com/v1
# AI_EXTERNAL_API_KEY=sk-...
# AI_EXTERNAL_VENDOR_APPROVED=true
# AI_DEIDENTIFY_REQUIRED=true

# ── Token TTLs (optional, defaults shown) ────────────────────────────────────
# ACCESS_TOKEN_TTL=900       # 15 minutes
# REFRESH_TOKEN_TTL=604800   # 7 days

# ── Backup (required only when using --profile backup) ───────────────────────
# GPG public key fingerprint or email for encrypting backups.
# See docs/BACKUP_RESTORE.md section 3 for key generation and import.
# BACKUP_GPG_RECIPIENT=ABCDEF1234567890ABCDEF1234567890ABCDEF12
