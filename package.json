{
  "name": "wr-evaluation-unified",
  "version": "3.2.1",
  "description": "근골격계 질환 업무관련성 평가 및 특별진찰 소견서 작성 도우미",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "mock:intranet": "node scripts/mock-intranet-server.cjs",
    "build:emr-helper": "powershell -ExecutionPolicy Bypass -File scripts/build-emr-helper.ps1",
    "build:web": "vite build --outDir dist/web",
    "build:electron": "vite build --outDir dist/electron",
    "preview": "vite preview",
    "electron:dev": "npm run build:emr-helper && vite build --outDir dist/electron && electron .",
    "electron:build": "npm run build:emr-helper && npm run build:electron && electron-builder",
    "electron:build:win32": "npm run build:emr-helper && npm run build:electron && electron-builder --win --ia32",
    "electron:build:win64": "npm run build:emr-helper && npm run build:electron && electron-builder --win --x64"
  },
  "dependencies": {
    "html2pdf.js": "^0.10.1",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^22.3.27",
    "electron-builder": "^24.9.1",
    "terser": "^5.46.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.wr-evaluation-unified.app",
    "productName": "직업성 질환 통합 평가 프로그램",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/electron/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "extraResources": [
      { "from": "electron/emr-helper/bin/Release/EmrHelper.exe", "to": "emr-helper/EmrHelper.exe" }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32",
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ko"
      ],
      "language": "1042"
    }
  }
}
