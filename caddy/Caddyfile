# wr-evaluation-unified — Caddy reverse proxy with internal CA
#
# Root CA certificate (install on every client PC):
#   docker compose exec caddy cat /data/caddy/pki/authorities/local/root.crt
#
# WR_DOMAIN env var must be set (e.g. wr.hospital.local).
# See docs/INTRANET_DEPLOYMENT.md for CA installation procedures.

{
	# Disable Caddy's public ACME — all certs are issued by internal CA only.
	auto_https disable_redirects

	pki {
		ca local {
			name "WR Evaluation Internal CA"
			intermediate_lifetime 365d
		}
	}
}

# HTTPS — terminate TLS with internal CA, proxy to the Express app.
# 컨테이너 내부는 표준 443으로 listen. 호스트 매핑은 docker-compose.yml에서 8443:443.
# Electron 클라이언트(electron/main.js)는 호스트 포트 8443으로 접속.
https://{$WR_DOMAIN} {
	tls {
		issuer internal {
			ca local
			lifetime 6d
		}
	}

	reverse_proxy app:3001

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		# Remove Caddy's server header to avoid fingerprinting.
		-Server
	}

	log {
		output stdout
		format json
	}
}

# HTTP → HTTPS redirect. 컨테이너 내부는 80, 호스트 매핑은 8080:80.
http://{$WR_DOMAIN} {
	redir https://{host}{uri} permanent
}
