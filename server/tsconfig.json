{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@wr/contracts": ["node_modules/@wr/contracts/dist/index.d.cts"],
      "@wr/contracts/*": ["node_modules/@wr/contracts/dist/*.d.cts"]
    }
  },
  "include": ["src/**/*.ts"]
}
