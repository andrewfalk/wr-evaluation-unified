# wr-evaluation-unified — PRODUCTION environment variables
#
# Copy to .env.production and fill in ALL values before starting.
#
#   cp .env.production.example .env.production
#   chmod 600 .env.production   # Linux
#
# ⚠ Rules:
#   - Never commit .env.production to git
#   - Never reuse dev/staging values — generate fresh secrets per install
#   - All blank values below are REQUIRED; compose will fail if left empty
#
# Usage:
#   docker compose \
#     -f docker-compose.yml \
#     -f docker-compose.prod.yml \
#     --env-file .env.production \
#     -p wr-prod \
#     up -d

# ── Auth tokens (required) ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# ── Network (required) ────────────────────────────────────────────────────────
# Intranet hostname as seen by client PCs (must resolve via DNS or hosts)
WR_DOMAIN=wr.hospital.local

# Comma-separated CORS allowed origins — must match WR_DOMAIN + 호스트 포트
# Caddy는 호스트 8443으로 매핑되므로 origin에 :8443 포함 필수 (Electron이 :8443으로 접속).
CORS_ORIGINS=https://wr.hospital.local:8443

# ── Database (required) ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Password for the read-only wr_audit_reader PostgreSQL role.
# After first docker compose up, run:
#   docker compose -p wr-prod exec postgres psql -U wr_user -d wr_evaluation \
#     -c "ALTER ROLE wr_audit_reader PASSWORD '<this value>';"
AUDIT_DB_PASSWORD=

# ── Backup (required when using --profile backup) ─────────────────────────────
# GPG public key fingerprint or email for encrypting daily backups.
# Register the public key once:
#   docker compose -p wr-prod --profile backup run --rm backup \
#     gpg --import /path/to/public-key.asc
# See docs/BACKUP_RESTORE.md section 3.
BACKUP_GPG_RECIPIENT=

# ── Image version ─────────────────────────────────────────────────────────────
# docker-compose.prod.yml pins app/backup-monitor/backup to wr-*:${WR_VERSION}.
# Must match the tag in release-manifest.json and the loaded wr-images.tar.
WR_VERSION=

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
DEPLOYMENT_MODE=intranet

# DEV_PORT: loopback binding — app must NOT be directly accessible externally.
# Caddy (ports 80/443) is the sole external entry point.
# docker-compose.prod.yml clears ports entirely via !reset — this value is unused
# in prod but kept here to prevent the base compose default (0.0.0.0:3001) from
# leaking if prod override is ever omitted by mistake.
DEV_PORT=127.0.0.1:3001

# ── AI (disabled by default in intranet deployment) ───────────────────────────
AI_PROVIDER=none
# Uncomment only if hospital-approved internal LLM is available:
# AI_PROVIDER=internal
# AI_INTERNAL_ENDPOINT=http://ollama:11434

# ── Token TTLs (optional — defaults shown) ───────────────────────────────────
# ACCESS_TOKEN_TTL=900       # 15 minutes
# REFRESH_TOKEN_TTL=604800   # 7 days

# ── 작업 영상 인간공학 분석 (6.0-9) ───────────────────────────────────────────
# 정책: **시범 운영(참고용)으로 활성화**. 정확도 검증(6.0-B2)은 진행 중이며, 그 전까지 영상
# 분석값은 "참고용"이다(UI 상단 시범 배너 + confidence 임계값 비활성 = 자동 차단 안 함).
# 값은 절대 자동 반영되지 않고 항상 전문의가 직접 확정한다. 의사의 수정 사유는 provenance에
# 누적되어 6.0-B2 검증 신호로 쓰인다. 검증 완료 시 임계값 배선(별도 PR)으로 적극 자동제안 전환.
#
# false로 두면 기능 전체가 잠긴다(전 라우트 404·워커 미기동·UI 스텝 숨김).
VIDEO_ANALYSIS_ENABLED=true
# 임시 영상/keypoints 공유 경로는 compose가 video_uploads 볼륨(/app/.video-uploads)으로 제공 —
# 여기서 덮어쓰지 말 것. 보존 정책 기본 privacy_first(원본은 추론 직후 삭제, skeleton만 검수).
# VIDEO_ANALYSIS_RETENTION=privacy_first
#
# ── 프라이버시 예외 게이트(기본 false = 식별 이미지 미노출) ─────────────────────
# 아래 둘은 얼굴·작업장이 드러나는 "식별 이미지"를 생성·노출하므로 기본 off다. 작업자 동의 +
# 인트라넷 한정 전제에서만 true로 켠다. 끄면(미설정 포함) UI는 중립 배경(박스·골격만)이라
# 업로드 후 대표 프레임 썸네일과 오버레이 검수의 실 원본 프레임이 "안 보이는" 게 정상 동작이다.
# ※ 켠 뒤에는 그 시점 "이후 새로 분석한 job"만 프레임을 보유한다(기존 job은 소급 안 됨 → 재분석 필요).
# 대상자 선택 캔버스에 대표 프레임을 배경으로 깔아 어느 박스가 작업자인지 식별 가능(증상: 업로드 썸네일).
# VIDEO_ANALYSIS_TARGET_THUMBNAIL=false
# 골격 오버레이 검수에서 골격 뒤에 실제(다운스케일 JPEG) 프레임을 깔아 정합 확인(증상: 오버레이 원본).
# VIDEO_ANALYSIS_OVERLAY_FRAMES=false
# 가중치 미반입 이미지를 어쩔 수 없이 쓸 때만(권장 안 함): 추론 recipe unverified 허용 → apply 가능.
# 운영 baked 이미지에선 절대 켜지 말 것(fail-closed가 위조/오염 가중치를 막는 안전장치).
# VIDEO_ANALYSIS_ALLOW_UNVERIFIED_RECIPE=false
# 추론 CPU/메모리 상한(16GB 서버에서 다른 서비스와 공존, 동시 1건). compose 기본 6g/4.
# APP_MEM_LIMIT=6g
# APP_CPUS=4
