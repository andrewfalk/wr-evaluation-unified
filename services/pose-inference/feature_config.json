{
  "version": "feature-calc-2026-06-a",
  "description": "feature 계산 규칙(6.0-6a). 각도 정의·임계값·OneEuro·품질 파라미터를 버전관리. 실제 임계값은 6.0-B2 검증으로 보정.",
  "keypointConvention": "coco17",
  "keypointIndex": {
    "nose": 0, "left_eye": 1, "right_eye": 2, "left_ear": 3, "right_ear": 4,
    "left_shoulder": 5, "right_shoulder": 6, "left_elbow": 7, "right_elbow": 8,
    "left_wrist": 9, "right_wrist": 10, "left_hip": 11, "right_hip": 12,
    "left_knee": 13, "right_knee": 14, "left_ankle": 15, "right_ankle": 16
  },
  "minKeypointConfidence": 0.3,
  "minHoldSec": 0.5,
  "frameDropMaxGapMs": 1000,
  "oneEuro": { "minCutoff": 1.0, "beta": 0.0, "dCutoff": 1.0 },
  "features": {
    "squatDuration": {
      "kind": "numeric", "metric": "posture_ratio", "unit": "ratio", "mode": "auto",
      "type": "joint_angle_posture",
      "joint": "knee", "side": "both", "reduce": "min",
      "condition": "lt", "thresholdDeg": 90,
      "note": "무릎각(hip-knee-ankle) < 90°가 연속 minHoldSec 이상 유지된 시간 비율. 양 무릎 중 더 굽은 쪽(min)."
    },
    "overheadHours": {
      "kind": "numeric", "metric": "posture_ratio", "unit": "ratio", "mode": "auto",
      "type": "overhead",
      "side": "any",
      "criteria": { "wristAboveShoulder": true, "upperarmElevationDeg": 90 },
      "note": "(손목 y < 어깨 y) OR (상완 거상각 >= 90°), 좌/우 어느 쪽이든. 연속 minHoldSec 이상 시간 비율."
    },
    "neckFlexionOver20HoursPerDay": {
      "kind": "numeric", "metric": "posture_ratio", "unit": "ratio", "mode": "auto",
      "type": "neck_flexion",
      "condition": "gt", "thresholdDeg": 20,
      "note": "목 굴곡각(어깨중점→귀중점 벡터의 수직 기준 전방 굴곡) > 20° 유지 시간 비율(PRD 20° 기준)."
    },
    "trunkPostureG": {
      "kind": "numeric", "metric": "peak_angle", "unit": "degrees", "mode": "candidate",
      "type": "trunk_flexion",
      "note": "체간 전굴각(엉덩이중점→어깨중점 벡터의 수직 기준) peak. G1~G11 매핑은 하중·작업유형 반영 필요 → candidate(수기 확인)."
    }
  }
}
